{
  "name": "preview-wallet-repo",
  "private": true,
  "workspaces": [
    "next-demo",
    "packages/*"
  ],
  "scripts": {
    "start:demo": "npm --workspace @preview-wallet/next-demo run dev",
    "start:wallet": "npm --workspace @preview-wallet/next-demo run wallet:start",
    "demo:check": "npm run wallet:check && npm --workspace @preview-wallet/next-demo run check",
    "wallet:check": "npm --workspace @preview-wallet/wallet run check && npm --workspace @preview-wallet/wallet run test",
    "package:pack": "npm pack --workspace @preview-wallet/wallet"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
