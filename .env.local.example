# Copy this file to .env.local for local development.
# Use a disposable dev-only private key. Never commit real secrets.

# Wallet runtime
PREVIEW_WALLET_PRIVATE_KEY=0xYOUR_DEV_PRIVATE_KEY_64_HEX_CHARS
NEXT_PUBLIC_NETWORK=sepolia
BSEP_RPC_URL=https://sepolia.base.org

# Optional overrides
# Public Base endpoints are rate-limited and not suitable for production.
# BASE_RPC_URL=https://mainnet.base.org
# PREVIEW_WALLET_HOST=127.0.0.1
# PREVIEW_WALLET_PORT=43199
