{
  "name": "preview-wallet-next-demo",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "wallet:install": "npm --prefix ../../tools/preview-wallet install",
    "wallet:start": "npm --prefix ../../tools/preview-wallet start",
    "wallet:check": "npm --prefix ../../tools/preview-wallet run check",
    "check": "npm run wallet:check && tsc --noEmit",
    "dev:wallet": "concurrently -k -n wallet,app -c green,blue \"npm run wallet:start\" \"npm run dev\""
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.90.21",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "viem": "^2.47.2",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "@types/react": "19.2.14",
    "concurrently": "^9.2.1",
    "typescript": "5.9.3"
  }
}
